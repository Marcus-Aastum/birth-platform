@page "/all-children"
@using BirthPlatform.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BirthContext> _contextFactory
@attribute [Authorize(Policy = "Healthcare")]

<MudDataGrid @ref="_childGrid" T="Child" Items="@_children" ReadOnly="false"
             EditMode="DataGridEditMode.Form"
             StartedEditingItem="@StartEditingItem"
             CommittedItemChanges="@CommittedItemChanges"
             Bordered="true" Dense="true" EditTrigger="DataGridEditTrigger.Manual"
             Filterable ="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Alle barn</MudText>
        <MudSpacer />

    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Navn"/>
        <PropertyColumn Property="x => x.BirthMother" Title="Fødemor"/>
        <PropertyColumn Property="x => x.BirthDate" Title="Fødselsdato" />
        <PropertyColumn Property="x => x.Municipality" Title="Kommune" />
        <PropertyColumn Property="x => x.Weight" Title="Vekt (gram)" />
        <PropertyColumn Property="x => x.Height" Title="Høyde (cm)" />
        <PropertyColumn Hidden="true" Property="x => x.Allergies.Count" Title="Antall allergier">
            <EditTemplate>
                <MudSelect T="string" Label="Allergier" MultiSelection="true" @bind-SelectedValues="_allergies">
                    @foreach (var allergy in allowedAllergies)
                    {
                        <MudSelectItem T="string" Value="@allergy">@allergy</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Hidden="true" Property="x => x.Conditions.Count" Title="Antall lidelser">
            <EditTemplate>
                <MudSelect T="string" Label="Lidelser" MultiSelection="true" @bind-SelectedValues="_conditions">
                    @foreach (var condition in allowedConditions)
                    {
                        <MudSelectItem T="string" Value="@condition">@condition</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property='x => x.Booking == null ? "ingen" : x.Booking.DoctorHPR' Title="Timebestilling">
            <EditTemplate>
                <MudCheckBox T="bool" Label="Ta timebestilling?" @bind-value="takeBooking">
                </MudCheckBox>
                @if (takeBooking)
                {
                    <MudTimePicker @bind-Time="bookingTime" Required="true" />
                    <MudDatePicker @bind-Date="bookingDate" Required="true" />
                }
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn CellClass="d-flex justify-between">
            <CellTemplate>
                <MudIconButton aria-label="Rediger barn" Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@context.Actions.StartEditingItemAsync" />
            </CellTemplate>
            <EditTemplate>
                <MudIconButton aria-label="Rediger barn" Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@context.Actions.StartEditingItemAsync" />
            </EditTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<Child> _children = [];
    private MudDataGrid<Child> _childGrid = default!;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool takeBooking;
    private TimeSpan? bookingTime;
    private DateTime? bookingDate = DateTime.Today;

    private IReadOnlyCollection<string> _allergies = [];
    private IEnumerable<string> allowedAllergies = [
    "Gluten", "Pollen", "Melk", "Pencilin", "Nøtter"
    ];

    private IReadOnlyCollection<string> _conditions = [];
    private IEnumerable<string> allowedConditions = [
    "Diabetes", "Cerebral parese", "Hørselstap", "Blind"
    ];

    protected override async Task OnInitializedAsync()
    {
        using (var dbcontext = _contextFactory.CreateDbContext())
        {
            _children = dbcontext.Children.ToList(); 
            var allBookings = dbcontext.Bookings.ToList();
            foreach (var child in _children)
            {
                child.Booking = allBookings.Where(x => x.ChildId == child.Id).FirstOrDefault();
            }
        }
    }

    private void DeleteItem(Child item)
    {
        _children.Remove(item);
    }

    private void StartEditingItem(Child item)
    {
        _allergies = item.Allergies.ToArray();
        _conditions = item.Conditions.ToArray();
    }

    private async Task<DataGridEditFormAction> CommittedItemChanges(Child item)
    {
        using (var dbcontext = _contextFactory.CreateDbContext())
        {
            var authState = await AuthState!;
            var hprNumber = authState.User.Claims.Where(x => x.Type == "helseid://claims/hpr/hpr_number").First();
            Booking? booking = null;
            if (takeBooking)
            {
                booking = new Booking()
                    {
                        Id = new Guid(),
                        //Child = item,
                        ChildId = item.Id,
                        DoctorHPR = hprNumber.Value,
                        Time = bookingDate + bookingTime ?? DateTime.Today,
                        Location = "Trondheim"
                    };
                dbcontext.Bookings.Add(booking);
                dbcontext.SaveChanges();
                item.Booking = booking;
            }
            item.Allergies = _allergies.ToArray();
            item.Conditions = _conditions.ToArray();
            dbcontext.Update(item);
            dbcontext.SaveChanges();
        }
        takeBooking = false;

        return DataGridEditFormAction.Close;
    }
}