@inherits LayoutComponentBase

<PageTitle>Fødselsplattformen</PageTitle>

<div class="page">
    <MudThemeProvider Theme="BirthPLatformTheme" />
    <MudPopoverProvider />

    <MudDialogProvider />

    <MudSnackbarProvider />
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="/authentication/logout" target="_blank">Logout</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
@code{
    MudTheme BirthPLatformTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#015945",
            Secondary = "#00467A"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Arial", "sans-serif" }
            }
        }
    };

}